LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Optional: allow token minting for non-loopback clients.
# `npm run dev:lan` sets this automatically — you do not need TRUST_PROXY for LAN access.
# ALLOW_REMOTE_TOKEN=1

# Only for deployments behind a reverse proxy. Pick ONE client-IP strategy:
#   TRUST_PROXY=1
#   TRUST_PROXY_HEADER=x-forwarded-for   # default; append-only proxies (trusted hop from the right)
#   TRUSTED_PROXY_HOPS=1
# or:
#   TRUST_PROXY=1
#   TRUST_PROXY_HEADER=x-real-ip         # proxies that overwrite a single validated header
