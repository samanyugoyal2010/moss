LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Optional. When set on the server, /api/token requires Authorization: Bearer <secret>.
# Mirror the same value in NEXT_PUBLIC_APP_SECRET so the browser can send it.
# Leave both unset for open local demos; set them before any public deploy.
# APP_SECRET=
# NEXT_PUBLIC_APP_SECRET=
