LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Optional server-only access code. When set, visitors unlock once via /api/gate
# (httpOnly cookie) before /api/token mints a LiveKit JWT. Never expose this as
# NEXT_PUBLIC_* — a client-bundled secret cannot protect the endpoint.
# Leave unset for open local demos; set before any public deploy.
# APP_SECRET=

# Set to 1 only behind a reverse proxy/platform that overwrites X-Forwarded-For /
# X-Real-IP. Vercel does this by default; other proxies must be configured to
# replace both headers rather than append to client-supplied values. Do not enable
# solely because traffic passes through a default Cloudflare or nginx setup.
# TRUST_PROXY=1
